{
  "title": "DermAI — API Monitoring",
  "uid": "dermai-monitoring",
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Total Predictions",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(dermai_requests_total{endpoint='/api/v1/predict'})",
        "legendFormat": "Total"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "teal" } }
      }
    },
    {
      "id": 2,
      "title": "Malignant vs Benign Predictions",
      "type": "piechart",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 8 },
      "targets": [
        { "expr": "dermai_malignant_predictions_total", "legendFormat": "Malignant" },
        { "expr": "dermai_benign_predictions_total",    "legendFormat": "Benign"    }
      ]
    },
    {
      "id": 3,
      "title": "API Request Latency (p95)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(dermai_request_latency_seconds_bucket[5m]))",
        "legendFormat": "p95 latency"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      }
    },
    {
      "id": 4,
      "title": "Confidence Score Distribution",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [{
        "expr": "rate(dermai_prediction_confidence_sum[5m]) / rate(dermai_prediction_confidence_count[5m])",
        "legendFormat": "Avg confidence"
      }],
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      }
    },
    {
      "id": 5,
      "title": "OOD Rejections",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "targets": [{
        "expr": "dermai_ood_rejections_total",
        "legendFormat": "OOD Rejections"
      }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" } }
      }
    },
    {
      "id": 6,
      "title": "Active Requests",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "targets": [{
        "expr": "dermai_active_requests",
        "legendFormat": "Active"
      }],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 10,
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 5, "color": "yellow" },
              { "value": 8, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Request Rate (req/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "rate(dermai_requests_total[1m]) * 60",
        "legendFormat": "{{endpoint}}"
      }]
    },
    {
      "id": 8,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "rate(dermai_requests_total{status=~'5..'}[5m])",
        "legendFormat": "5xx errors"
      }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } }
      }
    }
  ],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser"
}
